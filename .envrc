export TOP_HEAD="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"

unset GITHUB_TOKEN

# The nox binary lives in its own repo now; prefer a local debug build.
export PATH="$PATH:$TOP_HEAD/../nox/target/debug:$HOME/.local/bin"

export_alias _r "cd $TOP_HEAD && make run; cd -"
export_alias _t "cd $TOP_HEAD && make test; cd -"
